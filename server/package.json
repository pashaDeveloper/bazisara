{
  "name": "server",
  "version": "1.0.0",
  "description": "an intuitive eco shop server",
  "main": "index.js",
  "engines": {
    "node": "22.x",
    "npm": ">=8.x"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "node --check index.js && node --check app.js",
    "seed:icons": "node scripts/seedIcons.js",
    "seed:filters": "node scripts/seedFilterDefinitions.js",
    "seed:categories": "node scripts/seedCategories.js",
    "seed:genres": "node scripts/seedGenres.js",
    "seed:platforms": "node scripts/seedPlatforms.js",
    "seed:companies": "node scripts/seedCompanies.js",
    "seed:brands": "node scripts/seedBrands.js",
    "seed:category-filters": "node scripts/seedCategoryFilters.js",
    "seed:tags": "node scripts/seedTags.js",
    "seed:samples": "node scripts/seedCatalogSamples.js",
    "seed:game-collections": "node scripts/seedGameCollections.js",
    "seed:catalog": "npm run seed:icons && npm run seed:filters && npm run seed:categories && npm run seed:genres && npm run seed:companies && npm run seed:brands && npm run seed:platforms && npm run seed:category-filters && npm run seed:tags && npm run seed:samples && npm run seed:game-collections",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.738.0",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cloudinary": "^2.9.0",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "firebase-admin": "^14.0.0",
    "gcp-metadata": "^5.3.0",
    "google-translate-api-x": "^10.7.2",
    "jsonwebtoken": "^9.0.2",
    "melipayamak": "^1.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^2.2.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "stripe": "^14.13.0",
    "strong-soap": "^6.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
